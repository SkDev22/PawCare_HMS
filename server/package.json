{
  "name": "@pawcare/server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../.env -- ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "test": "jest --testPathPattern='\\.unit\\.test\\.ts$' --passWithNoTests",
    "test:integration": "jest --passWithNoTests",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:seed": "dotenv -e ../.env -- ts-node -r tsconfig-paths/register src/prisma/seed.ts",
    "db:studio": "dotenv -e ../.env -- prisma studio"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "dotenv -e ../.env -- ts-node -r tsconfig-paths/register src/prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@pawcare/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sendgrid/mail": "^8.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.10.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "sharp": "^0.33.0",
    "stripe": "^16.0.0",
    "twilio": "^5.2.0",
    "winston": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.0",
    "dotenv-cli": "^7.4.0",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
